# Port to listen on (example: 3000)
PORT=3000

DATABASE_URL=mongodb://localhost/pythagora
JWT_SECRET=
REFRESH_TOKEN_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=
FRONTEND_URL=

# Scheduler Configuration
# Cron expression for auto-repost polling (default: every minute)
SCHEDULER_CRON="* * * * *"

# Twitter API Configuration  
# Batch size for fetching tweets from Twitter (default: 10)
TWITTER_BATCH_SIZE=10
